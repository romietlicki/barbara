# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/whatsapp_digest"

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL="redis://localhost:6379"

# =============================================================================
# AUTH — compartilhado entre web e api
# Gere com: openssl rand -base64 32
# =============================================================================
AUTH_SECRET="your-secret-here-min-32-chars"

# Chave interna para chamadas Next.js → Fastify (nunca exposta ao browser)
# Gere com: openssl rand -hex 32
INTERNAL_API_KEY="your-internal-api-key-here"

# =============================================================================
# EVOLUTION API (WhatsApp Bridge)
# =============================================================================
EVOLUTION_API_URL="http://127.0.0.1:8080"
EVOLUTION_API_KEY="changeme-evolution-key"

# Segredo para validar HMAC-SHA256 dos webhooks recebidos
# Configure este mesmo valor no painel da Evolution API
EVOLUTION_WEBHOOK_SECRET="your-webhook-secret-here"

# =============================================================================
# ANTHROPIC (IA para geração de digests)
# =============================================================================
ANTHROPIC_API_KEY="sk-ant-..."

# =============================================================================
# CLOUDFLARE R2 (object storage para digests longos)
# =============================================================================
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="whatsapp-digest-prod"
R2_PUBLIC_URL="https://your-r2-public-url.r2.dev"

# =============================================================================
# STRIPE (billing por agência — uma assinatura por agência)
# =============================================================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# ID do price do plano recorrente criado no Stripe Dashboard
STRIPE_PRICE_ID="price_..."

# =============================================================================
# EMAIL (notificações de falha de conexão WA)
# =============================================================================
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER="resend"
SMTP_PASS="re_..."
EMAIL_FROM="noreply@seuapp.com"

# =============================================================================
# APP (Next.js)
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Domínio base para extração de slug nos subdomínios
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"
# Slug de agência usado em desenvolvimento local (localhost não tem subdomínio)
DEV_AGENCY_SLUG="acme"

# =============================================================================
# API (Fastify)
# =============================================================================
API_PORT="3001"
API_HOST="0.0.0.0"
LOG_LEVEL="info"
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"

# URL interna para apps/web → apps/api (server actions → Fastify)
# Dev: http://localhost:3001 | Docker: http://api:3001 | Prod: URL interna do Railway
INTERNAL_API_URL="http://localhost:3001"

# URL base do webhook da Evolution API (precisa ser alcançável pelo container da Evolution API)
# Dev com Docker: http://api:3001 | Prod: https://api.suaapp.com
EVOLUTION_WEBHOOK_BASE_URL="http://api:3001"
